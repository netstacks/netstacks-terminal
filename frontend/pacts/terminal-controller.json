{
  "consumer": {
    "name": "terminal"
  },
  "interactions": [
    {
      "description": "a login request when seats are full",
      "providerStates": [
        {
          "name": "all seats in use"
        }
      ],
      "request": {
        "body": {
          "email": "user@example.com",
          "password": "password123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.password": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/auth/login"
      },
      "response": {
        "body": {
          "error": "seat_limit_reached",
          "seats_total": 10,
          "seats_used": 10
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.seats_total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.seats_used": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 409
      }
    },
    {
      "description": "a login request with invalid credentials",
      "providerStates": [
        {
          "name": "admin user exists"
        }
      ],
      "request": {
        "body": {
          "email": "admin@example.com",
          "password": "wrongpassword"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.password": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/auth/login"
      },
      "response": {
        "body": {
          "error": "invalid_credentials"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 401
      }
    },
    {
      "description": "a login request with valid credentials",
      "providerStates": [
        {
          "name": "admin user exists"
        }
      ],
      "request": {
        "body": {
          "email": "admin@example.com",
          "password": "password123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.password": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/auth/login"
      },
      "response": {
        "body": {
          "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
          "expires_in": 3600,
          "refresh_token": "refresh-token-123",
          "token_type": "Bearer",
          "user": {
            "email": "admin@example.com",
            "id": "00000000-0000-0000-0000-000000000001",
            "name": "Admin User",
            "role": "admin"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.access_token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.expires_in": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.refresh_token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.token_type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.user.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.role": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for capabilities",
      "providerStates": [
        {
          "name": "controller is running with enterprise license"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer valid-token-123"
        },
        "method": "GET",
        "path": "/api/capabilities"
      },
      "response": {
        "body": {
          "features": [
            {
              "enabled": true,
              "name": "central_ssh"
            }
          ],
          "license_tier": "enterprise",
          "version": "1.0"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.features": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.features[*].enabled": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.features[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.license_tier": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for license status",
      "providerStates": [
        {
          "name": "valid enterprise license with 10 seats"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer valid-admin-token"
        },
        "method": "GET",
        "path": "/api/admin/license/status"
      },
      "response": {
        "body": {
          "active_sessions": [
            {
              "last_activity_at": "2026-02-02T12:00:00Z",
              "started_at": "2026-02-02T10:00:00Z",
              "user_email": "user@example.com"
            }
          ],
          "expires_at": "2026-12-31T23:59:59Z",
          "last_validated_at": "2026-02-02T00:00:00Z",
          "seats_total": 10,
          "seats_used": 3,
          "status": "valid",
          "tier": "enterprise",
          "warning_level": "none"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.active_sessions": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.active_sessions[*].last_activity_at": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.active_sessions[*].started_at": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.active_sessions[*].user_email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.expires_at": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.last_validated_at": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.seats_total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.seats_used": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tier": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.warning_level": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to activate invalid license",
      "providerStates": [
        {
          "name": "no active license"
        }
      ],
      "request": {
        "body": {
          "license_key": "INVALID-KEY"
        },
        "headers": {
          "Authorization": "Bearer valid-admin-token",
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.license_key": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/admin/license/activate"
      },
      "response": {
        "body": {
          "error": "License validation failed"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 400
      }
    },
    {
      "description": "a request to activate license",
      "providerStates": [
        {
          "name": "no active license"
        }
      ],
      "request": {
        "body": {
          "license_key": "TEST-KEY-1234-5678-90AB-CDEF"
        },
        "headers": {
          "Authorization": "Bearer valid-admin-token",
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.license_key": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/admin/license/activate"
      },
      "response": {
        "body": {
          "active_sessions": [],
          "expires_at": "2026-12-31T23:59:59Z",
          "last_validated_at": "2026-02-02T00:00:00Z",
          "seats_total": 10,
          "seats_used": 0,
          "status": "valid",
          "tier": "enterprise",
          "warning_level": "none"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.expires_at": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.last_validated_at": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.seats_total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.seats_used": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.tier": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.warning_level": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.0.4"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "controller"
  }
}