{
  "name": "netstacks-frontend",
  "private": true,
  "version": "0.0.23",
  "description": "Tauri frontend for NetStacks Terminal — AI-powered SSH terminal for network engineers.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/netstacks/netstacks-terminal.git"
  },
  "homepage": "https://netstacks.net",
  "bugs": {
    "url": "https://github.com/netstacks/netstacks-terminal/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build --base /terminal/ --outDir dist-web",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:pact": "vitest run --config vitest.pact.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:sidecar": "./scripts/build-sidecar.sh",
    "build:sidecar:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/build-sidecar-windows.ps1",
    "stage:sidecar": "node ./scripts/stage-sidecar.cjs",
    "build:app": "npm run build:sidecar && npm run tauri:build",
    "build:windows": "npm run build:sidecar:windows && npm run stage:sidecar && npm run tauri:build",
    "build:macos": "npm run build:sidecar && npm run tauri:build",
    "build:macos:universal": "BUILD_UNIVERSAL=1 npm run build:sidecar && npm run tauri:build -- --target universal-apple-darwin",
    "build:sidecar:linux": "./scripts/build-sidecar-linux.sh",
    "build:linux": "npm run build:sidecar:linux && npm run stage:sidecar && npm run tauri:build",
    "build:linux:appimage": "npm run build:linux -- --bundles appimage",
    "build:linux:deb": "npm run build:linux -- --bundles deb",
    "build:linux:rpm": "npm run build:linux -- --bundles rpm"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.21",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.13.2",
    "lucide-react": "^0.562.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-draggable": "^4.5.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "three": "^0.182.0",
    "xterm": "^5.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@pact-foundation/pact": "^16.0.4",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
